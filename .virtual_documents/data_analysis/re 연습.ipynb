text = """
홍길동 생일: 1990/05/21
김철수 생일: 1985-11-03
"""





# 1. 정규표현식 패턴 설정
# (\d{4}) : 연도 (숫자 4자리)
# [/-] : 구분자 (/ 또는 -)
# (\d{2}) : 월 (숫자 2자리)
# (\d{2}) : 일 (숫자 2자리)
# p = r"(\d{4})[/-](\d{2})[/-](\d{2})"
# 2. re.sub를 사용하여 형식 변경
# \1, \2, \3은 패턴에서 괄호()로 묶인 그룹을 순서대로 가져옵니다.
# m = re.sub(p, r"\1년 \2월 \3일", text)
# m


# 정규표현식으로 필요한 부분만 딱 뽑아서 리스트에 담기
# findall을 쓰면 결과가 [('1990', '05', '21'), ('1985', '11', '03')] 형태로 나옵니다.
m = re.findall(r"(\d{4})[/-](\d{2})[/-](\d{2})", text)

# 리스트 컴프리헨션을 사용하여 깔끔한 문자열 리스트 생성
[f"{y}년 {m}월 {d}일" for y, m, d in m]

# 결과: ['1990년 05월 21일', '1985년 11월 03일']


# 이름과 날짜를 동시에 추출하는 패턴
# (.*?): -> 이름 부분 추출
pattern = r"(.*?) 생일: (\d{4})[/-](\d{2})[/-](\d{2})"
matches = re.findall(pattern, text)

# {이름: 날짜} 형태의 딕셔너리 생성
birthday_dict = {name.strip(): f"{y}년 {m}월 {d}일" for name, y, m, d in matches}
birthday_dict


